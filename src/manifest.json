{
  "manifest_version": 3,
  "name": "阅读控制",
  "version": "1.0.0",
  "description": "通过语音控制网页阅读滚动",
  "permissions": ["activeTab", "sidePanel", "tabs"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/scroll.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "打开阅读控制"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "matches": ["<all_urls>"],
      "resources": ["speech-recognizer.js"]
    }
  ]
}
